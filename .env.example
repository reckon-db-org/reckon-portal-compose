# reckon-portal deployment — environment configuration
#
# Copy to .env and fill in values. Never commit .env.
#
# The product site has no database. The only required secrets are
# SECRET_KEY_BASE and the Mailgun credentials (for the contact form).

# =============================================================================
# Docker image version
# =============================================================================
# Pinned tag or `latest` for floating; watchtower will pull on change.
PORTAL_VERSION=latest

# =============================================================================
# Phoenix application
# =============================================================================
# Public hostname Caddy serves on. Must match the Caddyfile.
PHX_HOST=reckon-db.org

# Generate with: mix phx.gen.secret  (or: openssl rand -base64 64 | tr -d '\n')
SECRET_KEY_BASE=CHANGE_ME_USE_mix_phx_gen_secret

# Where the event-sourced blog (ReckonDB) persists its log inside the container.
# Backed by the blog_store_data volume; survives image auto-updates.
BLOG_STORE_DATA_DIR=/data/blog_store

# =============================================================================
# Mailgun — runs through Macula's Mailgun account on the macula.io domain
# =============================================================================
# Powers the /contact form. reckon-db.org has no verified sending domain, so
# mail goes out via Macula's Mailgun (domain mg.macula.io, From noreply@macula.io),
# exactly like macula-realm. Copy these three values straight from macula-realm's
# .env. Without them reckon-portal falls back to the Swoosh Local adapter
# (no send, no crash).
MACULA_MAILGUN_API_KEY=
MACULA_MAILGUN_DOMAIN=mg.macula.io
# EU region.
MACULA_MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
