# reckon-portal deployment — environment configuration
#
# Copy to .env and fill in values. Never commit .env.

# =============================================================================
# Docker image version
# =============================================================================
# Pinned tag or `latest` for floating; watchtower will pull on change.
PORTAL_VERSION=latest

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=reckon_portal
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
POSTGRES_DB=reckon_portal_prod

# Second database (Martha Projects app inside the umbrella)
POSTGRES_RECKON_MARTHA_DB=reckon_martha_projects

# =============================================================================
# Phoenix application
# =============================================================================
# Public hostname Caddy serves on. Must match the Caddyfile.
PHX_HOST=reckon-db.org

# Generate with: mix phx.gen.secret  (or: openssl rand -base64 64 | tr -d '\n')
SECRET_KEY_BASE=CHANGE_ME_USE_mix_phx_gen_secret

# Database pool sizes (defaults are fine for a single VM).
POOL_SIZE=10
MARTHA_PROJECTS_POOL_SIZE=10

# =============================================================================
# GitHub OAuth (user login)
# =============================================================================
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:  https://reckon-db.org
#   Callback URL:  https://reckon-db.org/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# GitHub API (optional — for repo metadata features in the portal)
# =============================================================================
# Personal access token (classic or fine-grained) with public_repo scope.
GITHUB_API_TOKEN=
