# reckon-portal deployment — environment configuration
#
# Copy to .env and fill in values. Never commit .env.

# =============================================================================
# Docker image version
# =============================================================================
# Pinned tag or `latest` for floating; watchtower will pull on change.
PORTAL_VERSION=latest

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=reckon_portal
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
POSTGRES_DB=reckon_portal_prod

# =============================================================================
# Phoenix application
# =============================================================================
# Public hostname Caddy serves on. Must match the Caddyfile.
PHX_HOST=reckon-db.org

# Generate with: mix phx.gen.secret  (or: openssl rand -base64 64 | tr -d '\n')
SECRET_KEY_BASE=CHANGE_ME_USE_mix_phx_gen_secret

# Database pool size (default is fine for a single VM).
POOL_SIZE=10

# =============================================================================
# GitHub OAuth (user login)
# =============================================================================
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:  https://reckon-db.org
#   Callback URL:  https://reckon-db.org/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# GitHub API (optional — for repo metadata features in the portal)
# =============================================================================
# Personal access token (classic or fine-grained) with public_repo scope.
GITHUB_API_TOKEN=

# =============================================================================
# Mailgun — uses the same Mailgun account as macula-realm
# =============================================================================
# Use the SAME API key value as MACULA_MAILGUN_API_KEY in macula-realm's .env.
# The Mailgun account is shared; only the verified sending domain differs.
RECKON_MAILGUN_API_KEY=
# EU region for both accounts.
RECKON_MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
# Verified sending domain for reckon-db.org. Set up via Mailgun dashboard:
# add MX/TXT/CNAME records on reckon-db.org's DNS for mg.reckon-db.org first.
RECKON_MAILGUN_DOMAIN=mg.reckon-db.org
RECKON_MAILGUN_FROM_EMAIL=noreply@reckon-db.org

# NOTE: reckon-portal/system/config/runtime.exs currently has the
# Mailgun adapter commented out. The env vars are plumbed here so the
# wire-up is one-liner away — uncomment the block + read these vars.
# Until then, Swoosh defaults to Local adapter and emails don't go out.

# =============================================================================
# Stripe — payments + membership tiers
# =============================================================================
# Phoenix dep: stripity_stripe ~> 2.17.0. Both keys required for prod.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Individual membership price IDs (monthly + annual)
STRIPE_MEMBER_MONTHLY_PRICE_ID=
STRIPE_VIP_MONTHLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_MEMBER_ANNUAL_PRICE_ID=
STRIPE_VIP_ANNUAL_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# B2B sponsorship tier price IDs (monthly + annual)
STRIPE_PLATINUM_MONTHLY_PRICE_ID=
STRIPE_GOLD_MONTHLY_PRICE_ID=
STRIPE_SILVER_MONTHLY_PRICE_ID=
STRIPE_COMMUNITY_SPONSOR_MONTHLY_PRICE_ID=
STRIPE_PLATINUM_ANNUAL_PRICE_ID=
STRIPE_GOLD_ANNUAL_PRICE_ID=
STRIPE_SILVER_ANNUAL_PRICE_ID=
STRIPE_COMMUNITY_SPONSOR_ANNUAL_PRICE_ID=
